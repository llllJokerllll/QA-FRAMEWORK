# QA-FRAMEWORK Backend Environment Configuration
# Copy this file to .env and fill in the values

# ===========================================
# ENVIRONMENT CONFIGURATION
# ===========================================

# Environment: development, staging, production
ENVIRONMENT=development

# ===========================================
# DATABASE (REQUIRED in production)
# ===========================================

# PostgreSQL connection URL
# Format: postgresql+asyncpg://user:password@host:port/database
# Example: postgresql+asyncpg://qa_user:secure_password@localhost:5432/qa_framework
DATABASE_URL=postgresql+asyncpg://qa_user:your_secure_password@localhost:5432/qa_framework_db

# ===========================================
# REDIS (REQUIRED for caching and sessions)
# ===========================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_if_any

# ===========================================
# JWT AUTHENTICATION (REQUIRED in production)
# ===========================================

# Generate a secure secret key:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your_jwt_secret_key_here_minimum_32_characters

# JWT token expiration (minutes)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===========================================
# STRIPE BILLING (REQUIRED if ENABLE_BILLING=true)
# ===========================================

# Enable billing features
ENABLE_BILLING=false

# Stripe API Key (sk_test_... for test, sk_live_... for production)
STRIPE_API_KEY=sk_test_your_stripe_api_key

# Stripe Webhook Secret (from Stripe Dashboard > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs (LIVE - created in Stripe Dashboard)
STRIPE_PRICE_FREE=price_1TEvdOI1MtlKoNQt5aepkf0d
STRIPE_PRICE_PRO=price_1TEvdOI1MtlKoNQtonZGU7S7
STRIPE_PRICE_ENTERPRISE=price_1TEvdPI1MtlKoNQtdRE8CP5m

# Stripe Product IDs (LIVE - created in Stripe Dashboard)
STRIPE_PRODUCT_FREE=prod_UDMMUYX064DjtC
STRIPE_PRODUCT_PRO=prod_UDMMlPYySnUofh
STRIPE_PRODUCT_ENTERPRISE=prod_UDMM2Yuc2VJAK3

# ===========================================
# APPLICATION URLs
# ===========================================

# Backend API URL
QA_FRAMEWORK_API_URL=http://localhost:8001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ===========================================
# LOGGING
# ===========================================

LOG_LEVEL=INFO

# ===========================================
# OPTIONAL: EXTERNAL SERVICES
# ===========================================

# Sentry error tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn

# Email configuration (optional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_email@example.com
# SMTP_PASSWORD=your_smtp_password

# ===========================================
# BROWSER-USE AI-POWERED TEST AUTOMATION
# ===========================================

# LLM Provider for Browser-Use (groq | openai | anthropic | ollama)
BROWSER_USE_LLM_PROVIDER=groq

# Groq API Key (get free at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Model to use (default: llama-3.3-70b-versatile)
BROWSER_USE_MODEL=llama-3.3-70b-versatile
